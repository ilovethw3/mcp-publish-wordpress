# Database Configuration
DATABASE_URL=postgresql://mcpuser:mcppassword@localhost:5432/mcpdb

# Security Configuration
SECRET_KEY=your-super-secret-jwt-signing-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API Key for External Agents
AGENT_API_KEY=your-agent-api-key-for-article-submission

# WordPress Integration
WORDPRESS_API_URL=https://your-wordpress-site.com/wp-json/wp/v2
WORDPRESS_USERNAME=your-wordpress-username
WORDPRESS_APP_PASSWORD=your-wordpress-application-password

# CORS Configuration  
FRONTEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8080"]

# Application Configuration
APP_NAME=MCP - Content Control Platform
APP_VERSION=1.0.0
DEBUG=false
EOF < /dev/null
